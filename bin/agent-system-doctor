#!/usr/bin/env python3
"""Validate the installed global system and optional repository wiring."""

from __future__ import annotations

import argparse
import hashlib
import json
import os
from pathlib import Path
import subprocess
import sys
import tomllib

sys.dont_write_bytecode = True

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from lib.codex_config import model_pin_paths
from lib.host_contract import cursor_rule, expected_cursor_hooks, expected_grouped_hooks, hook_budgets


CLAUDE_MODEL_ENV_KEYS = {
    "ANTHROPIC_MODEL",
    "ANTHROPIC_DEFAULT_OPUS_MODEL",
    "ANTHROPIC_DEFAULT_SONNET_MODEL",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL",
    "CLAUDE_MODEL",
    "CLAUDE_CODE_MODEL",
    "CLAUDE_CODE_SUBAGENT_MODEL",
}
SHELL_BLOCK_MARKER = "# >>> global agent invocation defaults >>>"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--home", type=Path, default=Path.home())
    parser.add_argument("--repo", type=Path)
    parser.add_argument("--strict-catalog", action="store_true")
    parser.add_argument("--json", action="store_true", dest="as_json")
    return parser.parse_args()


def read_json(path: Path, errors: list[str]) -> dict:
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        errors.append(f"invalid JSON {path}: {exc}")
        return {}
    if not isinstance(value, dict):
        errors.append(f"expected JSON object in {path}")
        return {}
    return value


def sha256_file(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(64 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


def contains_expected_events(actual: object, expected: dict) -> bool:
    if not isinstance(actual, dict):
        return False
    for event, expected_entries in expected.items():
        entries = actual.get(event)
        if not isinstance(entries, list):
            return False
        for expected_entry in expected_entries:
            if entries.count(expected_entry) != 1:
                return False
    return True


def validate_catalog(system_root: Path, errors: list[str]) -> dict:
    catalog_path = system_root / "system.json"
    catalog = read_json(catalog_path, errors)
    if catalog.get("schemaVersion") != 1:
        errors.append(f"unsupported catalog schema in {catalog_path}")

    skills = catalog.get("skills")
    if not isinstance(skills, list) or not skills:
        errors.append(f"catalog skills must be a non-empty list: {catalog_path}")
        skills = []
    skill_names: list[str] = []
    for entry in skills:
        if not isinstance(entry, dict) or not isinstance(entry.get("name"), str):
            errors.append(f"invalid skill entry in {catalog_path}")
            continue
        if not isinstance(entry.get("command"), bool):
            errors.append(f"skill command flag must be boolean: {entry.get('name')}")
        skill_names.append(entry["name"])
    if skill_names != sorted(set(skill_names)):
        errors.append("catalog skill names must be unique and sorted")
    source_skills = sorted(
        path.name
        for path in (system_root / "skills").iterdir()
        if path.is_dir() and (path / "SKILL.md").is_file()
    ) if (system_root / "skills").is_dir() else []
    if source_skills != skill_names:
        errors.append("system.json skill catalog does not match source directories")

    binaries = catalog.get("binaries")
    if not isinstance(binaries, list) or not binaries:
        errors.append(f"catalog binaries must be a non-empty list: {catalog_path}")
        binaries = []
    binary_names: list[str] = []
    for entry in binaries:
        if not isinstance(entry, dict) or not all(isinstance(entry.get(key), str) for key in ("name", "source")):
            errors.append(f"invalid binary entry in {catalog_path}")
            continue
        binary_names.append(entry["name"])
        source = system_root / entry["source"]
        if not source.is_file() or not os.access(source, os.X_OK):
            errors.append(f"missing executable catalog source: {source}")
    if binary_names != sorted(set(binary_names)):
        errors.append("catalog binary names must be unique and sorted")

    events = catalog.get("hookEvents")
    if events != ["Stop", "PreToolUse"]:
        errors.append("catalog hookEvents must be Stop and PreToolUse")
    try:
        hook_budgets(catalog)
    except ValueError as exc:
        errors.append(f"invalid catalog hook budgets: {exc}")
    return catalog


def exact_symlink(path: Path, target: Path) -> bool:
    return path.is_symlink() and path.resolve(strict=False) == target.resolve(strict=False)


def git_root(path: Path) -> bool:
    result = subprocess.run(
        ["git", "-C", str(path), "rev-parse", "--show-toplevel"],
        text=True,
        capture_output=True,
        check=False,
    )
    return result.returncode == 0 and Path(result.stdout.strip()).resolve() == path.resolve()


def main() -> int:
    args = parse_args()
    home = args.home.expanduser().resolve()
    agents = Path(os.environ.get("AGENTS_HOME", home / ".agents")).expanduser().resolve()
    errors: list[str] = []
    warnings: list[str] = []

    canonical = agents / "AGENTS.md"
    if not canonical.is_symlink():
        errors.append(f"canonical policy is not a managed symlink: {canonical}")
        system_root = Path(__file__).resolve().parent.parent
    else:
        system_root = canonical.resolve().parent
    catalog = validate_catalog(system_root, errors)
    try:
        budgets = hook_budgets(catalog)
    except ValueError:
        budgets = {"Stop": 330, "PreToolUse": 600}
    policy = system_root / str(catalog.get("policy", "AGENTS.md"))
    if not exact_symlink(canonical, policy):
        errors.append(f"bad canonical policy link: {canonical}")

    for adapter in (
        home / ".codex" / "AGENTS.md",
        home / ".claude" / "CLAUDE.md",
        home / ".claude" / "AGENTS.md",
    ):
        if not exact_symlink(adapter, policy):
            errors.append(f"bad policy adapter: {adapter}")

    dispatch = system_root / "hooks" / "dispatch.py"
    if not exact_symlink(agents / "hooks" / "dispatch.py", dispatch):
        errors.append("global hook dispatcher is not linked to the canonical source")
    config = read_json(agents / "config.json", errors)
    host_integration_raw = config.get("hostIntegrationRoot")
    if isinstance(host_integration_raw, str):
        host_integration = Path(host_integration_raw).expanduser().resolve()
    else:
        errors.append("agent hostIntegrationRoot configuration is invalid")
        host_integration = system_root / "host" / "local"
    launch_defaults = host_integration / "shell" / "default-invocations.sh"
    if (
        not exact_symlink(agents / "shell" / "default-invocations.sh", launch_defaults)
        or not launch_defaults.is_file()
        or not os.access(launch_defaults, os.R_OK)
    ):
        errors.append("default invocation adapter is not linked to the canonical source")
    for name in ("agent-claude", "agent-codex"):
        source = host_integration / "bin" / name
        for binary in (agents / "bin" / name, home / ".local" / "bin" / name):
            if not exact_symlink(binary, source) or not os.access(binary, os.X_OK):
                errors.append(f"bad host invocation helper: {binary}")

    catalog_skills = {entry["name"]: entry for entry in catalog.get("skills", []) if isinstance(entry, dict)}
    installed_skills = {
        path.name
        for path in (agents / "skills").iterdir()
        if path.is_dir() and (path / "SKILL.md").is_file()
    } if (agents / "skills").is_dir() else set()
    extensions = sorted(installed_skills - set(catalog_skills))
    if extensions:
        warnings.append(f"unmanaged skill extensions: {', '.join(extensions)}")
    for name, entry in catalog_skills.items():
        source = system_root / "skills" / name
        for adapter in (agents / "skills" / name, home / ".claude" / "skills" / name):
            if not exact_symlink(adapter, source):
                errors.append(f"bad skill adapter: {adapter}")
        if entry.get("command") is True:
            source_file = source / "SKILL.md"
            for command in (
                home / ".codex" / "prompts" / f"{name}.md",
                home / ".claude" / "commands" / f"{name}.md",
            ):
                if not exact_symlink(command, source_file):
                    errors.append(f"bad skill command adapter: {command}")
            cursor = home / ".cursor" / "commands" / f"{name}.md"
            try:
                if cursor.read_bytes() != source_file.read_bytes():
                    errors.append(f"stale Cursor command: {cursor}")
            except OSError as exc:
                errors.append(f"missing Cursor command {cursor}: {exc}")

    for entry in catalog.get("binaries", []):
        if not isinstance(entry, dict) or "name" not in entry or "source" not in entry:
            continue
        source = system_root / entry["source"]
        for binary in (agents / "bin" / entry["name"], home / ".local" / "bin" / entry["name"]):
            if not exact_symlink(binary, source) or not os.access(binary, os.X_OK):
                errors.append(f"bad executable helper: {binary}")

    claude_path = home / ".claude" / "settings.json"
    claude = read_json(claude_path, errors)
    if not contains_expected_events(
        claude.get("hooks"), expected_grouped_hooks("claude", budgets)
    ):
        errors.append(f"unexpected Claude hook configuration: {claude_path}")
    claude_env = claude.get("env") if isinstance(claude.get("env"), dict) else {}
    pins = sorted(CLAUDE_MODEL_ENV_KEYS & set(claude_env))
    if "model" in claude:
        pins.insert(0, "model")
    if pins:
        errors.append(f"Claude model pins remain: {', '.join(pins)}")
    if claude_env.get("CLAUDE_CODE_DISABLE_AUTO_MEMORY") != "1":
        errors.append("Claude auto-memory is not disabled")
    if claude.get("autoMemoryEnabled") is not False or claude.get("autoDreamEnabled") is not False:
        errors.append("Claude memory settings are not disabled")
    permissions = claude.get("permissions") if isinstance(claude.get("permissions"), dict) else {}
    if permissions.get("defaultMode") != "bypassPermissions":
        errors.append("Claude bypassPermissions is not the default")
    if claude.get("skipDangerousModePermissionPrompt") is not True:
        errors.append("Claude dangerous-mode acknowledgement is not persisted")

    codex_hooks_path = home / ".codex" / "hooks.json"
    codex_hooks = read_json(codex_hooks_path, errors)
    if not contains_expected_events(
        codex_hooks.get("hooks"), expected_grouped_hooks("codex", budgets)
    ):
        errors.append(f"unexpected Codex hook configuration: {codex_hooks_path}")
    cursor_hooks_path = home / ".cursor" / "hooks.json"
    cursor_hooks = read_json(cursor_hooks_path, errors)
    if cursor_hooks.get("version") != 1 or not contains_expected_events(
        cursor_hooks.get("hooks"), expected_cursor_hooks(budgets)
    ):
        errors.append(f"unexpected Cursor hook configuration: {cursor_hooks_path}")

    codex_config = home / ".codex" / "config.toml"
    try:
        codex_text = codex_config.read_text(encoding="utf-8")
        codex_values = tomllib.loads(codex_text)
    except (OSError, tomllib.TOMLDecodeError) as exc:
        errors.append(f"invalid Codex TOML {codex_config}: {exc}")
        codex_values = {}
    codex_pins = model_pin_paths(codex_values)
    if codex_pins:
        errors.append(f"Codex model pins remain: {', '.join(codex_pins)}")
    if codex_values.get("sandbox_mode") != "danger-full-access":
        errors.append("Codex danger-full-access sandbox is not the default")
    if codex_values.get("approval_policy") != "never":
        errors.append("Codex never-ask approval policy is not the default")
    features = codex_values.get("features")
    if not isinstance(features, dict) or features.get("memories") is not False:
        errors.append("Codex memories are not disabled")

    shell_paths = config.get("shellRcPaths")
    if not isinstance(shell_paths, list) or not all(isinstance(path, str) for path in shell_paths):
        errors.append("agent shellRcPaths configuration is invalid")
        shell_paths = []
    resolved_shell_paths = [Path(path).expanduser().resolve(strict=False) for path in shell_paths]
    expected_login = next(
        (
            path.resolve(strict=False)
            for path in (home / ".bash_profile", home / ".bash_login", home / ".profile")
            if path.exists()
        ),
        (home / ".bash_profile").resolve(strict=False),
    )
    expected_shell_paths = {
        (home / ".zshrc").resolve(strict=False),
        (home / ".bashrc").resolve(strict=False),
        expected_login,
    }
    if set(resolved_shell_paths) != expected_shell_paths:
        errors.append("configured shell startup files do not match effective shell startup paths")
    for rc_path in resolved_shell_paths:
        try:
            count = rc_path.read_text(encoding="utf-8").count(SHELL_BLOCK_MARKER)
        except OSError:
            count = 0
        if count != 1:
            errors.append(f"invocation source block count is {count}: {rc_path}")

    cursor_rule_path = home / ".cursor" / "rules" / "global-engineering.mdc"
    expected_rule = cursor_rule(policy.read_text(encoding="utf-8")) if policy.is_file() else ""
    try:
        if cursor_rule_path.read_text(encoding="utf-8") != expected_rule:
            errors.append(f"stale Cursor global rule: {cursor_rule_path}")
    except OSError as exc:
        errors.append(f"missing Cursor global rule {cursor_rule_path}: {exc}")

    coordination_raw = config.get("coordinationRepo")
    if not isinstance(coordination_raw, str) or not git_root(Path(coordination_raw).expanduser()):
        errors.append("agent coordination repository is not a valid Git root")
    managed = read_json(agents / "managed-install.json", errors)
    if managed.get("sourceRoot") != str(system_root):
        errors.append("managed install source root is stale")
    if managed.get("catalogSha256") != sha256_file(system_root / "system.json"):
        errors.append("managed install catalog hash is stale")
    orphaned = managed.get("orphanedPaths")
    if not isinstance(orphaned, list):
        errors.append("managed install orphan list is invalid")
    elif orphaned:
        errors.append(f"modified retired managed paths remain: {', '.join(orphaned)}")

    if args.repo:
        result = subprocess.run(
            [str(system_root / "bin" / "agent-repo-check"), "--repo", str(args.repo), "--strict"],
            text=True,
            capture_output=True,
            check=False,
        )
        if result.returncode:
            detail = result.stderr.strip() or result.stdout.strip()
            errors.append(f"repository check failed: {detail.splitlines()[-1] if detail else result.returncode}")

    if args.strict_catalog and extensions:
        errors.append("strict catalog rejects unmanaged skill extensions")

    report = {
        "systemRoot": str(system_root),
        "managedSkills": sorted(catalog_skills),
        "extensions": extensions,
        "errors": errors,
        "warnings": warnings,
    }
    if args.as_json:
        print(json.dumps(report, indent=2))
    elif errors:
        print("Agent system doctor: FAIL", file=sys.stderr)
        for error in errors:
            print(f"- {error}", file=sys.stderr)
        for warning in warnings:
            print(f"- warning: {warning}", file=sys.stderr)
    else:
        print("Agent system doctor: PASS")
        print(f"Managed skills: {', '.join(sorted(catalog_skills))}")
        if extensions:
            print(f"Extensions: {', '.join(extensions)}")
    return 1 if errors else 0


if __name__ == "__main__":
    raise SystemExit(main())
