#!/usr/bin/env python3
"""Wire a repository to the exact current global-system revision."""

from __future__ import annotations

import argparse
import json
import os
from pathlib import Path
import re
import subprocess
import sys
import tempfile


GLOBAL_POINTER = "READ ~/.agents/AGENTS.md BEFORE ANYTHING (skip if missing)."
MANAGED_MARKER = "# Managed by coding-agent-system."
GITHUB_HTTPS_RE = re.compile(r"^https://github\.com/([^/]+)/([^/]+?)(?:\.git)?/?$")
GITHUB_SSH_RE = re.compile(r"^(?:git@github\.com:|ssh://git@github\.com/)([^/]+)/([^/]+?)(?:\.git)?/?$")


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--repo", type=Path, default=Path.cwd())
    parser.add_argument("--system-ref")
    parser.add_argument("--check", action="store_true")
    parser.add_argument("--allow-unpublished", action="store_true", help=argparse.SUPPRESS)
    return parser.parse_args()


def git(repo: Path, *args: str) -> str:
    result = subprocess.run(
        ["git", "-C", str(repo), *args],
        text=True,
        capture_output=True,
        check=False,
    )
    if result.returncode:
        raise ValueError(result.stderr.strip() or f"git {' '.join(args)} failed")
    return result.stdout.strip()


def first_content_line(path: Path) -> str:
    for line in path.read_text(encoding="utf-8").splitlines():
        if line.strip():
            return line.strip()
    return ""


def safe_workflow_parent(repo: Path, path: Path) -> Path:
    for ancestor in (repo / ".github", repo / ".github" / "workflows"):
        if ancestor.is_symlink():
            raise ValueError(f"workflow ancestor must not be a symlink: {ancestor}")
    parent = path.parent.resolve(strict=False)
    if parent != repo and repo not in parent.parents:
        raise ValueError(f"workflow path escapes repository: {path}")
    return parent


def atomic_write(repo: Path, path: Path, content: str) -> None:
    safe_workflow_parent(repo, path)
    path.parent.mkdir(parents=True, exist_ok=True)
    safe_workflow_parent(repo, path)
    descriptor, raw_temp = tempfile.mkstemp(prefix=f".{path.name}.", dir=path.parent)
    temp = Path(raw_temp)
    try:
        with os.fdopen(descriptor, "w", encoding="utf-8") as handle:
            handle.write(content)
        if path.is_symlink():
            raise ValueError(f"workflow path must not be a symlink: {path}")
        safe_workflow_parent(repo, path)
        temp.replace(path)
    finally:
        temp.unlink(missing_ok=True)


def workflow(repository: str, revision: str) -> str:
    return f"""{MANAGED_MARKER}
name: Agent repository check

on:
  push:
  pull_request:

permissions:
  contents: read

jobs:
  repository-check:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v7
      - uses: {repository}@{revision}
"""


def github_repository(value: str) -> str | None:
    match = GITHUB_HTTPS_RE.fullmatch(value) or GITHUB_SSH_RE.fullmatch(value)
    return f"{match.group(1)}/{match.group(2)}" if match else None


def valid_action(content: str) -> bool:
    top_level = {
        match.group(1)
        for line in content.splitlines()
        if (match := re.match(r"^([A-Za-z][A-Za-z0-9_-]*):(?:\s|$)", line))
    }
    return {"name", "description", "runs"} <= top_level


def require_published(system_root: Path, repository: str, revision: str) -> None:
    origin = git(system_root, "config", "--get", "remote.origin.url")
    if github_repository(origin) != repository:
        raise ValueError(f"origin does not match catalog repository {repository}")
    git(
        system_root,
        "fetch",
        "--quiet",
        "--prune",
        "origin",
        "+refs/heads/*:refs/remotes/origin/*",
    )
    containing = git(
        system_root,
        "for-each-ref",
        f"--contains={revision}",
        "--format=%(refname)",
        "refs/remotes/origin/",
    )
    if not containing:
        raise ValueError(f"global system revision is not published on origin: {revision}")
    try:
        action = git(system_root, "show", f"{revision}:action.yml")
    except ValueError as exc:
        raise ValueError(f"published revision has no root action.yml: {revision}") from exc
    if not valid_action(action):
        raise ValueError(f"published revision has an invalid root action.yml: {revision}")


def main() -> int:
    args = parse_args()
    repo = args.repo.expanduser().resolve()
    system_root = Path(__file__).resolve().parent.parent
    errors: list[str] = []

    try:
        if Path(git(repo, "rev-parse", "--show-toplevel")).resolve() != repo:
            errors.append(f"--repo must be a Git root: {repo}")
        catalog = json.loads((system_root / "system.json").read_text(encoding="utf-8"))
        repository = catalog["repository"]
        revision = args.system_ref or git(system_root, "rev-parse", "HEAD")
    except (OSError, KeyError, ValueError, json.JSONDecodeError) as exc:
        print(f"agent-repo-adopt: {exc}", file=sys.stderr)
        return 1
    if not isinstance(repository, str) or not re.fullmatch(r"[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+", repository):
        errors.append("system catalog repository is invalid")
    if not re.fullmatch(r"[0-9a-f]{40}", revision):
        errors.append("--system-ref must be a full 40-character Git SHA")
    elif not args.allow_unpublished:
        try:
            require_published(system_root, repository, revision)
        except ValueError as exc:
            errors.append(str(exc))

    agents = repo / "AGENTS.md"
    if not agents.is_file() or first_content_line(agents) != GLOBAL_POINTER:
        errors.append("AGENTS.md must already begin with the canonical global pointer")
    claude = repo / "CLAUDE.md"
    if claude.exists() or claude.is_symlink():
        if not claude.is_symlink() or claude.resolve() != agents.resolve():
            errors.append("existing CLAUDE.md is not a symlink to AGENTS.md")

    workflow_path = repo / ".github" / "workflows" / "agent-repository-check.yml"
    expected = workflow(repository, revision)
    try:
        safe_workflow_parent(repo, workflow_path)
    except ValueError as exc:
        errors.append(str(exc))
    if workflow_path.is_symlink():
        errors.append(f"workflow path must not be a symlink: {workflow_path}")
    elif workflow_path.exists():
        current = workflow_path.read_text(encoding="utf-8")
        if not current.startswith(MANAGED_MARKER + "\n"):
            errors.append(f"refusing to replace unmanaged workflow: {workflow_path}")
        elif args.check and current != expected:
            errors.append(f"managed workflow is not pinned to {revision}")
    elif args.check:
        errors.append(f"missing managed workflow: {workflow_path}")

    if errors:
        for error in errors:
            print(f"agent-repo-adopt: {error}", file=sys.stderr)
        return 1
    if not args.check:
        if not claude.is_symlink():
            claude.symlink_to("AGENTS.md")
        try:
            atomic_write(repo, workflow_path, expected)
        except ValueError as exc:
            print(f"agent-repo-adopt: {exc}", file=sys.stderr)
            return 1

    result = subprocess.run(
        [str(system_root / "bin" / "agent-repo-check"), "--repo", str(repo), "--strict"],
        text=True,
        capture_output=True,
        check=False,
    )
    if result.returncode:
        detail = result.stderr.strip() or result.stdout.strip()
        print(detail, file=sys.stderr)
        return result.returncode
    action = "verified" if args.check else "adopted"
    print(f"Repository {action}: {repo}")
    print(f"Global system revision: {revision}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
